NODE_ENV=production
PORT=5000
FRONTEND_URL=https://krishok-sheba-bd.vercel.app
PUBLIC_BASE_URL=https://krishok-sheba-bd.onrender.com

# Railway injects MYSQL_URL when the MySQL service is linked to this service.
# Outside Railway, set MYSQL_PUBLIC_URL to the resolved public connection URL.
MYSQL_URL=
MYSQL_PUBLIC_URL=
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=railway

# Optional DB_* aliases for other MySQL providers.
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=সুপার অ্যাডমিন
RESET_TOKEN_EXPIRES_MINUTES=30
MAX_UPLOAD_MB=5

# Recommended for permanent uploads on Render
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
