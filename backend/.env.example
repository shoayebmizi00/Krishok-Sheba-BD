NODE_ENV=production
PORT=5000
FRONTEND_URL=https://krishok-sheba-bd.vercel.app
PUBLIC_BASE_URL=https://krishok-sheba-bd.onrender.com

# Supabase session-mode pooler URL for the continuously running Express service.
DATABASE_URL=postgresql://postgres.project-ref:password@pooler-host:5432/postgres
DB_CONNECTION_LIMIT=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=Super Admin
RESET_TOKEN_EXPIRES_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=KRISHOK-SHEBA BD <no-reply@example.com>
MAX_UPLOAD_MB=5

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
