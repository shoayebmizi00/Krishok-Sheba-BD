{
  "name": "krishok-sheba-bd-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node scripts/start-production.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js",
    "test": "node --import ./tests/setup-env.js --test tests/*.test.js",
    "migrate": "node scripts/migrate.js",
    "db:check": "node scripts/check-database.js",
    "db:init": "npm run migrate && npm run db:seed",
